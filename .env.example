# Public runtime config (safe to expose in frontend)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Confidential server config (required)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-before-production
SESSION_SECRET=replace-with-a-long-random-secret

# Optional server storage override
# Hosted platform uses /data; defaults to OS temp directory otherwise.
ARTICLE_STORAGE_DIR=/data